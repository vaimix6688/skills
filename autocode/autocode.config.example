# ============================================
# AutoCode Configuration
# Copy this file to autocode.config and customize
# ============================================

# Project Configuration
PROJECT_NAME=MyProject
PROJECT_ROOT=/path/to/repos

# Repository Map (key=short_name, value=folder_name)
# Add entries for each repo in your project
REPO_MAP_core=myproject-core
REPO_MAP_frontend=myproject-frontend
REPO_MAP_infra=myproject-infra
# REPO_MAP_crypto=myproject-crypto
# REPO_MAP_compliance=myproject-compliance
# REPO_MAP_ingestion=myproject-ingestion
# REPO_MAP_ai=myproject-ai
# REPO_MAP_docs=myproject-docs

# AutoCode Settings
DEFAULT_AGENT=engineering-senior-developer
MAX_TURNS=200
MAX_RETRIES=10
MAX_COST_USD=10
DOCKER_SANDBOX=false

# Iteration Mode (inspired by Karpathy's autoresearch)
# When INPUT_MODE=program, uses program.md (exploratory direction) instead of spec (strict requirements)
# When METRIC_CMD is set, enables keep/discard pattern: run metric after each change,
# rollback if metric worsens (e.g. test coverage drops, bundle size increases, perf regresses)
INPUT_MODE=spec
# INPUT_MODE=program
METRIC_CMD=
# METRIC_CMD=npm run test -- --coverage | grep 'All files' | awk '{print $10}'
# METRIC_CMD=cargo bench --bench main 2>&1 | grep 'time:' | awk '{print $3}'
# METRIC_CMD=du -sb dist/ | awk '{print $1}'
METRIC_DIRECTION=lower_is_better
# METRIC_DIRECTION=higher_is_better
MAX_TIME_PER_ITERATION=300
# Time budget in seconds per iteration (default 300 = 5 minutes, 0 = no limit)

# Integration
REPOMIX_ENABLED=false
REPOMIX_OUTPUT=.repomix-output.xml
HEADROOM_ENABLED=false
HEADROOM_PORT=8080

# State Management (resume interrupted specs)
STATE_DIR=.autocode-state
# Each spec creates: STATE_DIR/{spec-name}/notepad.md, phase-log.json, errors.log
# AutoCode checks state dir before running and resumes from last phase if interrupted
# State is cleaned up after successful completion

# Logging
LOG_DIR=autocode/logs
LOG_LEVEL=info
